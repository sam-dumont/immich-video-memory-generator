apiVersion: v1
kind: Secret
metadata:
  name: immich-memories-secrets
  namespace: immich-memories
  labels:
    app.kubernetes.io/name: immich-memories
type: Opaque
stringData:
  # Replace with your actual values or use sealed-secrets/external-secrets
  IMMICH_URL: "https://photos.example.com"
  IMMICH_API_KEY: "your-immich-api-key-here"
  # Optional: For OpenAI fallback mood analysis
  OPENAI_API_KEY: ""
  # Optional: Pixabay API key for music search
  PIXABAY_API_KEY: ""
