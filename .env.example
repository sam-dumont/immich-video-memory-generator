# Immich Memories — environment variables
# Copy to .env and fill in your values.

# Required: Immich server connection
IMMICH_URL=https://photos.example.com
IMMICH_API_KEY=your-api-key-here

# Optional: session secret (auto-generated if not set, set for multi-replica/K8s)
# IMMICH_MEMORIES_STORAGE_SECRET=change-me

# Optional: basic auth for the web UI
# IMMICH_MEMORIES_AUTH_USERNAME=admin
# IMMICH_MEMORIES_AUTH_PASSWORD=change-me

# Optional: LLM for clip content analysis (any OpenAI-compatible API)
# IMMICH_MEMORIES_LLM__BASE_URL=http://your-llm:8080/v1
# IMMICH_MEMORIES_LLM__MODEL=qwen2.5-vl
