# Copy this file to terraform.tfvars and fill in your values

# Immich connection
immich_url     = "https://photos.example.com"
immich_api_key = "your-immich-api-key-here"

# Optional: API keys
openai_api_key  = ""  # For LLM content analysis fallback

# Optional: Ollama for local LLM (privacy-friendly)
ollama_url = "http://localhost:11434"

# Analysis settings
use_scene_detection = true  # Use natural scene boundaries (default)
enable_downscaling  = true  # Faster analysis at 480p (default)

# Content analysis (LLM-based, disabled by default)
content_analysis_enabled = false
